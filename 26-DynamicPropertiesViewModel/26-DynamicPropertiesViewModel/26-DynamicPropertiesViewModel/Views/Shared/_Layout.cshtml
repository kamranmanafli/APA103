<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dynamic Properties ViewModel</title>
    <style>
            body {
                margin: 0;
                font-family: Arial, Helvetica, sans-serif;
                color: #1f2937;
                background: #f4f6f8;
            }

            header {
                background: #143d59;
                color: white;
                padding: 18px 36px;
            }

            nav {
                display: flex;
                gap: 18px;
                margin-top: 12px;
            }

            nav a {
                color: #dbeafe;
                text-decoration: none;
                font-weight: 700;
            }

            main {
                max-width: 1100px;
                margin: 0 auto;
                padding: 32px 20px;
            }

            section {
                background: white;
                border: 1px solid #d8dee8;
                border-radius: 8px;
                margin-bottom: 20px;
                padding: 22px;
            }

            h1, h2 {
                margin-top: 0;
            }

            table {
                width: 100%;
                border-collapse: collapse;
            }

            th, td {
                border-bottom: 1px solid #e5e7eb;
                padding: 10px;
                text-align: left;
            }

            th {
                background: #e8eef5;
            }

            .note {
                background: #fff7ed;
                border-color: #fed7aa;
            }

            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
                gap: 20px;
            }
    </style>
</head>
<body>
    <header>
        <h1>Lesson 26</h1>
        <nav>
            <a asp-controller="Home" asp-action="Index">ViewModel</a>
            <a asp-controller="Home" asp-action="Details">Dynamic Properties</a>
            <a href="/korporativ-satislar">Corporate Sales Route</a>
        </nav>
    </header>
    <main>
        @RenderBody()
    </main>
</body>
</html>

